<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 顶部进度条 -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/primary"
        android:progressBackgroundTint="@android:color/transparent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 下拉刷新 + WebView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 错误提示页面 -->
    <LinearLayout
        android:id="@+id/errorLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvErrorIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😵"
            android:textSize="64sp" />

        <TextView
            android:id="@+id/tvErrorMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/load_error"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/retry"
            android:textAllCaps="false"
            app:cornerRadius="20dp" />

    </LinearLayout>

    <!-- 悬浮菜单组：固定大小确保展开区域可点击 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/fabMenuContainer"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 子按钮：回到主页 (洋红) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:contentDescription="@string/menu_home"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_home"
            android:visibility="gone"
            app:backgroundTint="@color/cyber_magenta"
            app:fabSize="mini"
            app:layout_constraintBottom_toBottomOf="@id/btnAddShortcut"
            app:layout_constraintEnd_toEndOf="@id/btnAddShortcut"
            app:layout_constraintStart_toStartOf="@id/btnAddShortcut"
            app:layout_constraintTop_toTopOf="@id/btnAddShortcut"
            app:rippleColor="@color/white"
            app:tint="@color/white" />

        <!-- 子按钮：历史记录 (亮黄) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:contentDescription="@string/menu_history"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_history"
            android:visibility="gone"
            app:backgroundTint="@color/cyber_yellow"
            app:fabSize="mini"
            app:layout_constraintBottom_toBottomOf="@id/btnAddShortcut"
            app:layout_constraintEnd_toEndOf="@id/btnAddShortcut"
            app:layout_constraintStart_toStartOf="@id/btnAddShortcut"
            app:layout_constraintTop_toTopOf="@id/btnAddShortcut"
            app:rippleColor="@color/white"
            app:tint="@color/splash_bg" />

        <!-- 子按钮：访问网址 (蓝色) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabGoTo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:contentDescription="@string/menu_go_to"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_link"
            android:visibility="gone"
            app:backgroundTint="@color/primary"
            app:fabSize="mini"
            app:layout_constraintBottom_toBottomOf="@id/btnAddShortcut"
            app:layout_constraintEnd_toEndOf="@id/btnAddShortcut"
            app:layout_constraintStart_toStartOf="@id/btnAddShortcut"
            app:layout_constraintTop_toTopOf="@id/btnAddShortcut"
            app:rippleColor="@color/white"
            app:tint="@color/white" />

        <!-- 子按钮：添加到桌面 (白色) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabShortcut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:contentDescription="@string/menu_shortcut"
            android:scaleX="0"
            android:scaleY="0"
            android:src="@drawable/ic_add_to_home"
            android:visibility="gone"
            app:backgroundTint="@color/white"
            app:fabSize="mini"
            app:layout_constraintBottom_toBottomOf="@id/btnAddShortcut"
            app:layout_constraintEnd_toEndOf="@id/btnAddShortcut"
            app:layout_constraintStart_toStartOf="@id/btnAddShortcut"
            app:layout_constraintTop_toTopOf="@id/btnAddShortcut"
            app:rippleColor="@color/cyber_cyan"
            app:tint="@color/splash_bg" />

        <!-- 主按钮 (青色) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnAddShortcut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="@string/add_to_home"
            android:src="@drawable/ic_add_to_home"
            app:backgroundTint="@color/cyber_cyan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:rippleColor="@color/cyber_magenta"
            app:tint="@color/splash_bg" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 赛博朋克闪屏叠加层 -->
    <include
        android:id="@+id/splashOverlay"
        layout="@layout/activity_splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
