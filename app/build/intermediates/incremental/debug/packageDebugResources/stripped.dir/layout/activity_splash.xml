<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Background Grid Effect (Simple implementation) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.05"
        android:background="@color/cyber_cyan" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/cyber_cyan"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:shadowColor="@color/cyber_cyan"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="20"
        app:layout_constraintBottom_toTopOf="@id/tvSlogan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Secondary "Glitch" Text (Offset) -->
    <TextView
        android:id="@+id/tvAppNameGlitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/cyber_magenta"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:alpha="0.5"
        android:translationX="2dp"
        android:translationY="1dp"
        app:layout_constraintBottom_toBottomOf="@id/tvAppName"
        app:layout_constraintEnd_toEndOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="@id/tvAppName"
        app:layout_constraintTop_toTopOf="@id/tvAppName" />

    <TextView
        android:id="@+id/tvSlogan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="> INITIALIZING_SYSTEM..."
        android:textColor="@color/cyber_yellow"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <!-- Decorative Corner Elements -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_margin="24dp"
        android:background="@color/cyber_cyan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:layout_width="2dp"
        android:layout_height="40dp"
        android:layout_margin="24dp"
        android:background="@color/cyber_cyan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_margin="24dp"
        android:background="@color/cyber_magenta"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
    <View
        android:layout_width="2dp"
        android:layout_height="40dp"
        android:layout_margin="24dp"
        android:background="@color/cyber_magenta"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
